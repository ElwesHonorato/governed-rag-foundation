# ---------------------------------------------------------
# Environment Configuration
#
# This file defines all runtime configuration for the local
# RAG stack, including infrastructure services, application
# endpoints, credentials, and tuning parameters.
#
# Usage:
#   - Copy this file to `.env`
#   - Adjust values as needed per environment
#
# Notes:
#   - This configuration is intended for local development
#   - Do NOT use default credentials in production
#   - Ports must remain unique across services
# ---------------------------------------------------------

# =========================================================
# NETWORK
# =========================================================
STACK_NETWORK=rag-local

# =========================================================
# SERVICE PORTS
# =========================================================
# Storage & Data
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
POSTGRES_PORT=5432

# Search & Vector
WEAVIATE_PORT=8080
ELASTICSEARCH_PORT=9200
VECTOR_UI_PORT=8011

# Messaging
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672

# Data Platform (DataHub + dependencies)
DATAHUB_GMS_PORT=8081
DATAHUB_FRONTEND_PORT=9003
DATAHUB_KAFKA_PORT=9092
DATAHUB_MYSQL_PORT=3306
DATAHUB_SCHEMA_REGISTRY_PORT=8082
DATAHUB_ZOOKEEPER_PORT=2181
DATAHUB_NEO4J_HTTP_PORT=7474
DATAHUB_NEO4J_BOLT_PORT=7687

# Applications & APIs
LLM_PORT=11434
AI_UI_PORT=8000
AGENT_API_PORT=8010

# Infrastructure Tools
PORTAINER_HTTP_PORT=9002
PORTAINER_HTTPS_PORT=9443

# =========================================================
# CREDENTIALS (DEVELOPMENT ONLY)
# =========================================================
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=minio123

RABBITMQ_DEFAULT_USER=guest
RABBITMQ_DEFAULT_PASS=guest

# =========================================================
# INTERNAL SERVICE URLS (DOCKER NETWORK)
# =========================================================
WEAVIATE_URL=http://weaviate:8080
ELASTICSEARCH_URL=http://elasticsearch:9200

BROKER_URL=amqp://guest:guest@rabbitmq:5672/%2F

S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minio
S3_SECRET_KEY=minio123

DATAHUB_GMS_SERVER=http://datahub-gms:8080

LLM_URL=http://ollama:11434
AGENT_API_URL=http://agent-api:8010

# =========================================================
# LLM CONFIGURATION
# =========================================================
LLM_MODEL=llama3.2:1b
LLM_TIMEOUT_SECONDS=30

# =========================================================
# AGENT CONFIGURATION
# =========================================================
AGENT_API_TIMEOUT_SECONDS=30

# =========================================================
# STORAGE CONFIGURATION
# =========================================================
ELASTICSEARCH_POC_S3_ENDPOINT=http://localhost:9000
ELASTICSEARCH_POC_S3_BUCKET=rag-data
ELASTICSEARCH_POC_S3_PREFIX=DEV/04_chunks/
ELASTICSEARCH_POC_S3_ACCESS_KEY=minio
ELASTICSEARCH_POC_S3_SECRET_KEY=minio123

# =========================================================
# SEARCH CONFIGURATION
# =========================================================
ELASTICSEARCH_POC_URL=http://localhost:9201
ELASTICSEARCH_POC_INDEX=rag_chunks

# Weaviate tuning
WEAVIATE_QUERY_DEFAULTS_LIMIT=25

# =========================================================
# WORKER CONFIGURATION
# =========================================================
WORKER_POLL_INTERVAL_SECONDS=30
SOURCE_TYPE=html

# =========================================================
# DATAHUB / LINEAGE CONFIGURATION
# =========================================================
DATAHUB_TOKEN=

LINEAGE_TIMEOUT_SECONDS=3.0
LINEAGE_RETRY_MAX_ATTEMPTS=3
LINEAGE_RETRY_BACKOFF_INITIAL_SECONDS=0.5
LINEAGE_RETRY_BACKOFF_MULTIPLIER=2.0
LINEAGE_RETRY_BACKOFF_MAX_SECONDS=5.0

# =========================================================
# SECURITY
# =========================================================
DEFAULT_SECURITY_CLEARANCE=internal

# =========================================================
# ENVIRONMENT
# =========================================================
ENV=DEV
